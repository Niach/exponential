{
  "$schema": "./schema.json",
  "description": "Canonical enum values shared by the web, iOS, and Android clients. Regenerate the per-language constants with `bun run --filter @exp/domain-contract generate`. The committed generated files (apps/ios/.../Domain.generated.swift, apps/android/.../Domain.generated.kt) are checked in so mobile builds don't need a Node runtime.",
  "issueStatus": {
    "values": ["backlog", "todo", "in_progress", "done", "cancelled"],
    "displayOrder": ["in_progress", "todo", "backlog", "done", "cancelled"]
  },
  "issuePriority": {
    "values": ["none", "urgent", "high", "medium", "low"],
    "displayOrder": ["urgent", "high", "medium", "low", "none"]
  },
  "recurrenceUnit": {
    "values": ["day", "week", "month"]
  },
  "workspaceRole": {
    "values": ["owner", "member", "agent"]
  },
  "publicWritePolicy": {
    "values": ["members", "everyone"]
  },
  "commentKind": {
    "values": ["regular"]
  },
  "agentPlanState": {
    "values": [
      "drafting",
      "awaiting_approval",
      "awaiting_answer",
      "approved",
      "coding",
      "planning",
      "in_review",
      "pushed"
    ]
  },
  "notificationType": {
    "values": [
      "issue_assigned",
      "issue_comment",
      "issue_status_changed",
      "issue_mention",
      "agent_plan_review",
      "agent_question"
    ]
  },
  "prState": {
    "values": ["open", "closed", "merged", "draft"]
  },
  "runMode": {
    "values": ["background", "interactive"]
  },
  "subscriberSource": {
    "values": ["creator", "assignee", "commenter", "manual", "mention"]
  },
  "issueEventType": {
    "values": [
      "status_changed",
      "assignee_changed",
      "label_added",
      "label_removed",
      "pr_opened",
      "pr_merged",
      "plan_ready",
      "agent_error",
      "agent_started",
      "agent_question",
      "agent_answer"
    ]
  },
  "recurrenceIntervals": [1, 2, 3, 4, 5, 6, 7, 8, 10, 12, 14, 21, 30],
  "moderationRestrictedFields": [
    "status",
    "priority",
    "assigneeId",
    "dueDate",
    "dueTime",
    "endTime",
    "recurrenceInterval",
    "recurrenceUnit",
    "archivedAt"
  ],
  "agentPipeline": {
    "nonTerminalStatuses": ["queued", "claimed", "planning", "awaiting_approval", "coding", "pushed"],
    "reentryStatuses": ["queued", "cancelled", "failed", "awaiting_approval", "needs_human"],
    "planRevisionCap": 8
  }
}
