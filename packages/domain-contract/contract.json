{
  "$schema": "./schema.json",
  "description": "Canonical enum values shared by the web, iOS, Android, and desktop clients. Regenerate the per-language constants with `bun run --filter @exp/domain-contract generate`. The committed generated files (apps/ios/.../DomainContract.generated.swift, apps/android/.../DomainContract.generated.kt, apps/desktop/crates/domain/src/contract.generated.rs) are checked in so native builds don't need a Node runtime.",
  "issueStatus": {
    "values": ["backlog", "todo", "in_progress", "in_review", "done", "cancelled", "duplicate"],
    "displayOrder": ["in_progress", "in_review", "todo", "backlog", "done", "cancelled", "duplicate"]
  },
  "issuePriority": {
    "values": ["none", "urgent", "high", "medium", "low"],
    "displayOrder": ["urgent", "high", "medium", "low", "none"]
  },
  "teamRole": {
    "values": ["owner", "member"]
  },
  "boardIcon": {
    "values": [
      "code",
      "square-kanban",
      "megaphone",
      "bug",
      "rocket",
      "book-open",
      "globe",
      "heart",
      "star",
      "zap",
      "wrench",
      "shield",
      "package",
      "terminal",
      "lightbulb",
      "message-circle"
    ]
  },
  "commentKind": {
    "values": ["regular"]
  },
  "notificationType": {
    "values": [
      "issue_assigned",
      "issue_comment",
      "issue_status_changed",
      "issue_mention",
      "issue_created",
      "pr_opened",
      "pr_merged",
      "support_reply"
    ]
  },
  "prState": {
    "values": ["open", "closed", "merged", "draft"]
  },
  "codingSessionStatus": {
    "values": ["running", "in_review", "ended"]
  },
  "codingSession": {
    "staleHours": 2
  },
  "subscriberSource": {
    "values": ["creator", "assignee", "commenter", "manual", "mention", "widget_reporter"]
  },
  "issueEventType": {
    "values": [
      "status_changed",
      "assignee_changed",
      "label_added",
      "label_removed",
      "pr_opened",
      "pr_merged",
      "board_moved"
    ]
  },
  "codingAgent": {
    "values": ["claude", "codex", "pi"]
  },
  "codingModel": {
    "values": ["fable", "opus", "sonnet"]
  },
  "codingEffort": {
    "values": ["low", "medium", "high", "xhigh", "max"]
  },
  "codexModel": {
    "values": ["gpt-5.6-sol", "gpt-5.6-terra", "gpt-5.6-luna"]
  },
  "codexEffort": {
    "values": ["minimal", "low", "medium", "high", "xhigh"]
  },
  "piModel": {
    "values": [
      "fable",
      "opus",
      "sonnet",
      "gpt-5.6-sol",
      "gpt-5.6-terra",
      "gpt-5.6-luna",
      "grok-4.5"
    ]
  },
  "piThinking": {
    "values": ["off", "minimal", "low", "medium", "high", "xhigh", "max"]
  }
}
