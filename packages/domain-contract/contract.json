{
  "$schema": "./schema.json",
  "description": "Canonical enum values shared by the web, iOS, Android, and desktop clients. Regenerate the per-language constants with `bun run --filter @exp/domain-contract generate`. The committed generated files (apps/ios/.../DomainContract.generated.swift, apps/android/.../DomainContract.generated.kt, apps/desktop/crates/domain/src/contract.generated.rs) are checked in so native builds don't need a Node runtime.",
  "issueStatus": {
    "values": ["backlog", "todo", "in_progress", "in_review", "done", "cancelled", "duplicate"],
    "displayOrder": ["in_progress", "in_review", "todo", "backlog", "done", "cancelled", "duplicate"]
  },
  "issuePriority": {
    "values": ["none", "urgent", "high", "medium", "low"],
    "displayOrder": ["urgent", "high", "medium", "low", "none"]
  },
  "workspaceRole": {
    "values": ["owner", "member"]
  },
  "projectIcon": {
    "values": [
      "code",
      "square-kanban",
      "megaphone",
      "bug",
      "rocket",
      "book-open",
      "globe",
      "heart",
      "star",
      "zap",
      "wrench",
      "shield",
      "package",
      "terminal",
      "lightbulb",
      "message-circle"
    ]
  },
  "commentKind": {
    "values": ["regular"]
  },
  "notificationType": {
    "values": [
      "issue_assigned",
      "issue_comment",
      "issue_status_changed",
      "issue_mention",
      "issue_created",
      "pr_opened",
      "pr_merged",
      "support_reply"
    ]
  },
  "prState": {
    "values": ["open", "closed", "merged", "draft"]
  },
  "codingSessionStatus": {
    "values": ["running", "ended"]
  },
  "subscriberSource": {
    "values": ["creator", "assignee", "commenter", "manual", "mention", "widget_reporter"]
  },
  "issueEventType": {
    "values": [
      "status_changed",
      "assignee_changed",
      "label_added",
      "label_removed",
      "pr_opened",
      "pr_merged",
      "project_moved"
    ]
  }
}
