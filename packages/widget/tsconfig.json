{
  "extends": "@exp/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    // Only vite/client (for `?inline` CSS imports): the hoisted node_modules
    // contains @types/react from other workspaces, and an open `types` would
    // let React's global JSX types bleed into this Preact package.
    "types": ["vite/client"]
  },
  "include": ["src"]
}
