{
  "name": "exponential",
  "private": true,
  "version": "0.13.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "bun --filter @exp/web dev",
    "dev:marketing": "bun --filter @exp/marketing dev",
    "dev:push-relay": "bun --filter @exp/push-relay dev",
    "start:push-relay": "bun --filter @exp/push-relay start",
    "dev:steer-relay": "bun --filter @exp/steer-relay dev",
    "start:steer-relay": "bun --filter @exp/steer-relay start",
    "test:steer-relay": "bun --filter @exp/steer-relay test && bun --filter @exp/steer-ticket test",
    "build": "bun --filter @exp/widget build && bun --filter @exp/web build && bun --filter @exp/marketing build",
    "build:web": "bun --filter @exp/web build",
    "build:widget": "bun --filter @exp/widget build",
    "dev:widget": "bun --filter @exp/widget dev",
    "test:widget": "bun --filter @exp/widget test",
    "build:marketing": "bun --filter @exp/marketing build",
    "start": "bun --filter @exp/web start",
    "test": "bun --filter @exp/web test",
    "test:e2e": "bun --filter @exp/web test:e2e",
    "typecheck": "bun --filter @exp/web typecheck",
    "migrate": "bun --filter @exp/web migrate",
    "migrate:generate": "bun --filter @exp/web migrate:generate",
    "psql": "bun --filter @exp/web psql",
    "android:build": "cd apps/android && ./gradlew :app:assembleProductionDebug",
    "android:build:staging": "cd apps/android && ./gradlew :app:assembleStagingDebug",
    "android:install": "cd apps/android && ./gradlew :app:installProductionDebug",
    "android:install:staging": "cd apps/android && ./gradlew :app:installStagingDebug",
    "dev:desktop": "cd apps/desktop && cargo run -p app",
    "build:desktop": "cd apps/desktop && cargo build --release",
    "test:desktop": "cd apps/desktop && cargo test",
    "backend:up": "docker compose up -d",
    "backend:down": "docker compose down",
    "backend:clear": "docker compose down -v",
    "storage:init": "bash scripts/garage-init.sh",
    "lint": "bun --filter '*' lint",
    "lint:check": "bun --filter '*' lint:check",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.2",
    "@eslint/compat": "^1.3.1",
    "@eslint/js": "^9.32.0",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.6.2",
    "typescript": "^5.7.2"
  }
}
