# Database connection URL for PostgreSQL
# This should match the database configuration in docker-compose.yaml
DATABASE_URL=postgresql://postgres:password@localhost:54321/exponential

# Authentication secret - REQUIRED in production
# Generate a strong secret (minimum 32 characters)
BETTER_AUTH_SECRET=

# Electric Cloud Configuration (optional)
# Get these from https://dashboard.electric-sql.cloud/
# or use `npx @electric-sql/start` to provision automatically.
# If not set, it will try to connect to local Electric at `http://localhost:30000`
# and you can start it using `bun run backend:up`
#
# ELECTRIC_URL=https://api.electric-sql.cloud
# ELECTRIC_SOURCE_ID=your-source-id
# ELECTRIC_SECRET=your-source-secret

# S3-compatible attachment storage (Garage by default; any S3 API works)
# Run `bun run storage:init` after `bun run backend:up` to create the bucket
# and an access key, then paste the printed credentials below.
S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=exponential-attachments
# S3_REGION=garage

# Authentication (optional)
# AUTH_PASSWORD_ENABLED=false   # disable email/password sign-in

# OIDC providers — JSON array, one entry per provider.
# Each entry: { id, name, clientId, clientSecret, discoveryUrl, scopes?, adminGroups?, groupsClaim? }
# `id` is used as the provider key and also as the accounts.providerId value.
# `name` is the label shown on the login/register buttons.
# `adminGroups` (optional): list of group names whose members are auto-promoted
#   to global admin. Re-evaluated on every login (so removing a user from the
#   group revokes admin). When set, scopes default to
#   ["openid","profile","email","groups"] unless overridden.
# `groupsClaim` (optional, default "groups"): dotted path into the OIDC profile
#   where group names live. Example: "realm_access.roles" for Keycloak.
# Authorized redirect URI (per provider): ${BETTER_AUTH_URL}/api/auth/oauth2/callback/<id>
# OIDC_PROVIDERS='[
#   {"id":"authentik","name":"Authentik","clientId":"...","clientSecret":"...","discoveryUrl":"https://auth.example.com/application/o/app/.well-known/openid-configuration","adminGroups":["exponential-admins"]},
#   {"id":"keycloak","name":"Keycloak","clientId":"...","clientSecret":"...","discoveryUrl":"https://kc.example.com/realms/main/.well-known/openid-configuration","adminGroups":["admin"],"groupsClaim":"realm_access.roles"}
# ]'

# Legacy single-provider OIDC vars (still supported when OIDC_PROVIDERS is unset).
# AUTH_OIDC_ENABLED=true
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_DISCOVERY_URL=https://auth.example.com/application/o/app/.well-known/openid-configuration
# OIDC_PROVIDER_ID=authentik

# Google OAuth (optional)
# Setting these enables BOTH "Sign in with Google" on the login/register pages
# AND the Google Calendar integration on /account/integrations.
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
# Calendar integration scope: https://www.googleapis.com/auth/calendar.events
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub (optional) — lets users connect GitHub on /account/integrations so the
# desktop agent can clone/push their repos and the server can open PRs + show
# diffs on their behalf. Create an OAuth App at
# https://github.com/settings/developers
# Authorization callback URL: ${BETTER_AUTH_URL}/api/auth/callback/github
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GitHub webhook secret — CLOUD merge detection. Configure a repo/org webhook
# (content type application/json) pointed at ${BETTER_AUTH_URL}/api/webhooks/github
# with this secret. Self-hosted instances skip this and use an outbound cron
# (gated by SELF_HOSTED below) instead.
# GITHUB_WEBHOOK_SECRET=

# Self-hosted mode (optional)
# Set to 'true' for self-hosted deployments. Disables billing, unlocks all
# plan limits. Leave unset or empty for the cloud instance.
# SELF_HOSTED=true

# Creem billing (cloud-only; leave unset for self-hosted)
# Create products at https://creem.io/dashboard and note the product IDs.
# CREEM_API_KEY=
# CREEM_WEBHOOK_SECRET=
# CREEM_PRO_PRODUCT_ID=
# CREEM_BUSINESS_PRODUCT_ID=

# Push relay shared secret
# Must match between the web app and push relay. On cloud, this prevents
# self-hosted instances from using push.exponential.at. Self-hosted users
# must set the same secret in both their web app and their own push relay.
# PUSH_RELAY_SECRET=
