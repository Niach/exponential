# Database connection URL for PostgreSQL
# This should match the database configuration in docker-compose.yaml
DATABASE_URL=postgresql://postgres:password@localhost:54321/exponential

# Authentication secret - REQUIRED in production
# Generate a strong secret (minimum 32 characters)
BETTER_AUTH_SECRET=

# Electric Cloud Configuration (optional)
# Get these from https://dashboard.electric-sql.cloud/
# or use `npx @electric-sql/start` to provision automatically.
# If not set, it will try to connect to local Electric at `http://localhost:30000`
# and you can start it using `bun run backend:up`
#
# ELECTRIC_URL=https://api.electric-sql.cloud
# ELECTRIC_SOURCE_ID=your-source-id
# ELECTRIC_SECRET=your-source-secret

# S3-compatible attachment storage (Garage by default; any S3 API works)
# Run `bun run storage:init` after `bun run backend:up` to create the bucket
# and an access key, then paste the printed credentials below.
S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=exponential-attachments
# S3_REGION=garage

# Authentication (optional)
# AUTH_PASSWORD_ENABLED=false   # disable email/password sign-in
# Public password sign-up. Default: enabled in dev, DISABLED in production
# (invite/OAuth only). Set 'true' to open registration on a production
# instance (recommended together with RESEND_API_KEY so verification +
# password-reset emails work), 'false' to force-disable anywhere.
# AUTH_SIGNUP_ENABLED=true

# Transactional email via Resend (https://resend.com) — powers password
# reset + email verification + email notifications. Unset: those flows are
# disabled gracefully (the login page hides "Forgot password?"). EMAIL_FROM
# must be a verified sender/domain in your Resend account.
# RESEND_API_KEY=
# EMAIL_FROM="Exponential <noreply@exponential.at>"

# Self-hosted alternative: plain SMTP via nodemailer. Used only when
# RESEND_API_KEY is unset (Resend wins when both are configured). With neither
# set, all email sends are logged no-ops — in-app + push notifications still
# work. SMTP_PORT defaults to 587 (STARTTLS); SMTP_SECURE defaults to true for
# port 465 (implicit TLS), false otherwise. SMTP_USER/SMTP_PASS are optional
# (unauthenticated relays). EMAIL_FROM above is reused as the sender.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false

# OIDC providers — JSON array, one entry per provider.
# Each entry: { id, name, clientId, clientSecret, discoveryUrl, scopes?, adminGroups?, groupsClaim? }
# `id` is used as the provider key and also as the accounts.providerId value.
# `name` is the label shown on the login/register buttons.
# `adminGroups` (optional): list of group names whose members are auto-promoted
#   to global admin. Re-evaluated on every login (so removing a user from the
#   group revokes admin). When set, scopes default to
#   ["openid","profile","email","groups"] unless overridden.
# `groupsClaim` (optional, default "groups"): dotted path into the OIDC profile
#   where group names live. Example: "realm_access.roles" for Keycloak.
# Authorized redirect URI (per provider): ${BETTER_AUTH_URL}/api/auth/oauth2/callback/<id>
# OIDC_PROVIDERS='[
#   {"id":"authentik","name":"Authentik","clientId":"...","clientSecret":"...","discoveryUrl":"https://auth.example.com/application/o/app/.well-known/openid-configuration","adminGroups":["exponential-admins"]},
#   {"id":"keycloak","name":"Keycloak","clientId":"...","clientSecret":"...","discoveryUrl":"https://kc.example.com/realms/main/.well-known/openid-configuration","adminGroups":["admin"],"groupsClaim":"realm_access.roles"}
# ]'

# Legacy single-provider OIDC vars (still supported when OIDC_PROVIDERS is unset).
# AUTH_OIDC_ENABLED=true
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_DISCOVERY_URL=https://auth.example.com/application/o/app/.well-known/openid-configuration
# OIDC_PROVIDER_ID=authentik

# Google OAuth (optional)
# Setting these enables "Sign in with Google" on the login/register pages.
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Show "Sign in with Google" on login/register (requires the client vars above).
# GOOGLE_LOGIN_ENABLED=true

# Sign in with Apple (optional; REQUIRED for the iOS App Store when Google
# login is enabled — guideline 4.8). APPLE_CLIENT_ID is the Apple *Services ID*
# with Return URL ${BETTER_AUTH_URL}/api/auth/callback/apple. Provide the SIWA
# .p8 key (base64 -w0 AuthKey_XXX.p8) + key/team ids and the server mints the
# ≤6-month client-secret JWT fresh at every boot; a static APPLE_CLIENT_SECRET
# is also honored (and wins) if set.
# APPLE_CLIENT_ID=
# APPLE_PRIVATE_KEY=
# APPLE_KEY_ID=
# APPLE_TEAM_ID=
# APPLE_LOGIN_ENABLED=true
# APPLE_APP_BUNDLE_IDENTIFIER=at.exponential

# GitHub App (required for DEV projects — cloud AND self-host) — workspaces
# CONNECT GitHub accounts (App installations) from workspace settings →
# Repositories. The server mints short-lived per-repo installation tokens
# just-in-time to open PRs + read diffs; desktop coding sessions use the same
# per-repo token to clone/push. No broad user token is stored.
#
# !!! A dev project IS a repository. An instance WITHOUT GITHUB_APP_ID /
# !!! GITHUB_APP_SLUG / GITHUB_APP_PRIVATE_KEY cannot create dev projects — the
# !!! create-project UI surfaces "This instance has no GitHub App configured".
#
# Create a
# GitHub App at https://github.com/settings/apps
# (Settings → Developer settings → GitHub Apps → New GitHub App):
#   - Setup URL: ${BETTER_AUTH_URL}/api/integrations/github/setup
#     and tick "Redirect on update" (repo-grant changes round-trip through it)
#   - Callback URL (OAuth, for the workspace claim flow):
#     ${BETTER_AUTH_URL}/api/integrations/github/callback
#   - Webhook URL (cloud only): ${BETTER_AUTH_URL}/api/webhooks/github
#   - Permissions: Contents (read/write), Pull requests (read/write),
#     Metadata (read); subscribe to the Pull request event. (installation /
#     installation_repositories events are delivered to GitHub Apps
#     automatically once the webhook is Active — they are not listed under
#     "Subscribe to events".)
#   - Leave "Request user authorization (OAuth) during installation"
#     UNCHECKED — the workspace claim flow triggers OAuth itself.
# GITHUB_APP_ID is the numeric App ID; GITHUB_APP_SLUG is the App's URL slug
# (used to build the install link). GITHUB_APP_PRIVATE_KEY is the App's PEM
# private key, base64-encoded (so the multi-line PEM survives env/compose):
#   base64 -w0 your-app.private-key.pem
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=
# GITHUB_APP_PRIVATE_KEY=
# GitHub App OAuth client credentials (STRONGLY RECOMMENDED) — power the
# workspace "Connect GitHub" claim flow: a single mobile-friendly authorize
# screen instead of GitHub's install/configure page. The user token is used
# once (to enumerate the user's installations) and DISCARDED — never stored.
# Generate a client secret on the App's settings page. Unset → the connect
# flow falls back to the install-page round-trip.
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
# GitHub webhook secret — CLOUD merge detection. The App's single app-level
# webhook auto-delivers Pull request events for every installation; verify them
# with this secret. Self-hosted instances behind NAT skip the webhook and set
# GITHUB_POLLING=true (below) to run an outbound merge cron instead.
# GITHUB_WEBHOOK_SECRET=
# Outbound merge-detection cron — set to 'true' on instances GitHub cannot reach
# by webhook (self-hosted behind NAT). Decoupled from SELF_HOSTED. Leave unset on
# cloud (the webhook handles it) and on desktops (pr_poll handles it).
# GITHUB_POLLING=true

# Self-hosted mode (optional)
# Set to 'true' for self-hosted deployments. Disables billing, unlocks all
# plan limits. Leave unset or empty for the cloud instance.
# SELF_HOSTED=true

# Creem billing (cloud-only; leave unset for self-hosted)
# Create products at https://creem.io/dashboard and note the product IDs.
# CREEM_API_KEY=
# CREEM_WEBHOOK_SECRET=
# CREEM_PRO_PRODUCT_ID=
# CREEM_BUSINESS_PRODUCT_ID=
# CREEM_BUSINESS_YEARLY_PRODUCT_ID=

# Push relay (optional) — forwards FCM pushes to mobile devices.
# PUSH_RELAY_URL is the relay's base URL (cloud: https://push.exponential.at).
# PUSH_RELAY_SECRET must match between the web app and the relay. On cloud, this
# prevents self-hosted instances from using push.exponential.at. Self-hosted
# users must set the same secret in both their web app and their own push relay.
# The relay process itself (apps/push-relay) additionally needs
# FIREBASE_SERVICE_ACCOUNT_JSON — the raw JSON of a Firebase service-account key
# (Firebase Console → Project settings → Service accounts). It is read by the
# relay only, never by the web app.
# PUSH_RELAY_URL=
# PUSH_RELAY_SECRET=

# Steer relay (optional) — the outbound WebSocket hub for remote "Start on my
# desktop" + live terminal watch/steer. Unset ⇒ the whole subsystem is off
# (mintTicket returns disabled; local coding is unaffected), mirroring how
# PUSH_RELAY_URL unset disables push.
# STEER_RELAY_URL is the relay base the desktop + clients dial (cloud:
# wss://steer.exponential.at; LAN self-host: ws://relay.lan:4002). The web app
# derives the http(s) origin from it for its server-to-server relay calls.
# STEER_RELAY_SECRET is the shared HS256 secret: the web app signs relay tickets
# and authenticates its /devices, /start, /kill calls with it; the relay verifies
# ticket signatures with the same value. Must match between web app and relay.
# STEER_RELAY_URL=
# STEER_RELAY_SECRET=

# Security headers (optional) — set to 'true' to emit CSP/HSTS/etc. from the
# Bun server. Recommended in production when the app is served directly
# (reverse proxies that already set these can leave it off).
# SECURITY_HEADERS_ENABLED=true

# Bootstrap global admins (optional, cloud) — comma-separated emails promoted
# to global admin at startup.
# INITIAL_ADMIN_EMAILS=admin@example.com
