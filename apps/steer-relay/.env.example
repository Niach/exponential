# Shared HS256 secret between the web app and this relay — required; without
# it the relay refuses connections (503 on everything but /healthz). Must equal
# STEER_RELAY_SECRET on the web app, which mints the tickets this relay
# verifies.
STEER_RELAY_SECRET=

# Set to 'true' ONLY when a trusted reverse proxy that appends the real client
# address to X-Forwarded-For fronts the relay — it keys the per-IP WebSocket
# rate limits by that address. MANDATORY in any proxied deployment (the
# documented Coolify/Traefik setup included): without it every connect
# worldwide keys to one shared fallback bucket. Off by default because
# forwarded headers from unknown peers are client-forgeable.
# TRUST_PROXY=true

# Port to listen on (default: 4002)
# PORT=4002
