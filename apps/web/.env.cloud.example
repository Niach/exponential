# Cloud-specific environment for app.exponential.at.
# Copy into Coolify's app env tab. Values starting with `<…>` are placeholders.

# --- Database ---
DATABASE_URL=postgres://exponential:<password>@postgres:5432/exponential

# --- Electric ---
ELECTRIC_URL=http://electric:3000

# --- Better Auth ---
BETTER_AUTH_SECRET=<32+ char secret>
BETTER_AUTH_URL=https://app.exponential.at
BETTER_AUTH_TRUSTED_ORIGINS=https://app.exponential.at

# Cloud is Google-only by design — no password, no generic OIDC.
AUTH_PASSWORD_ENABLED=false
AUTH_OIDC_ENABLED=false
GOOGLE_LOGIN_ENABLED=true
GOOGLE_CALENDAR_ENABLED=true
GOOGLE_CLIENT_ID=<google oauth client id>
GOOGLE_CLIENT_SECRET=<google oauth client secret>

# --- Cloud-only bootstrap & feature flags ---
# Comma-separated emails that get promoted to is_admin=true on first sign-in
# (and on every server boot, idempotent). Match the Google email exactly.
INITIAL_ADMIN_EMAILS=niach95@gmail.com

# Self-hosted instances set PUBLIC_FEEDBACK_URL to this cloud's URL so their
# Send-feedback button deep-links here. The cloud itself leaves it unset.
# PUBLIC_FEEDBACK_URL=

# Production-only response hardening (CSP, HSTS, X-Frame-Options, etc.)
SECURITY_HEADERS_ENABLED=true

# --- S3-compatible storage (Garage) ---
S3_ENDPOINT=http://garage:3900
S3_ACCESS_KEY=<garage access key>
S3_SECRET_KEY=<garage secret key>
S3_BUCKET=exponential-attachments
S3_REGION=garage

# --- Push relay ---
PUSH_RELAY_URL=https://push.exponential.at

# --- Runtime ---
NODE_ENV=production
PORT=3000
