# The web app's runtime env file is a symlink to the repo-root `.env`
# (see `apps/web/.env -> ../../.env`). This file documents every variable
# the web app actually reads; copy what you need into the root `.env`.

# --- Core / required ---------------------------------------------------
# PostgreSQL connection string used by Drizzle and tRPC
DATABASE_URL=postgresql://postgres:password@localhost:54321/electric
# 32+ char secret used by Better Auth to sign sessions
BETTER_AUTH_SECRET=
# Base URL of the app, used by Better Auth for OAuth callbacks
BETTER_AUTH_URL=http://localhost:5173
# Comma-separated list of origins Better Auth will accept requests from
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173

# --- ElectricSQL --------------------------------------------------------
# Defaults to http://localhost:30000 (the local docker compose service)
ELECTRIC_URL=http://localhost:30000
# Optional Electric Cloud credentials (only when using hosted Electric)
# ELECTRIC_SOURCE_ID=
# ELECTRIC_SECRET=

# --- S3-compatible attachment storage (Garage by default) --------------
# Run `bun run storage:init` to bootstrap credentials
S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=exponential-attachments
S3_REGION=garage

# --- Authentication toggles --------------------------------------------
# Disable email/password sign-in (default: enabled)
# AUTH_PASSWORD_ENABLED=false
# Legacy single-provider OIDC switch (see OIDC_PROVIDERS for the new form)
# AUTH_OIDC_ENABLED=true

# --- OIDC (multi-provider) ---------------------------------------------
# JSON array; each entry: { id, name, clientId, clientSecret, discoveryUrl,
#   scopes?, adminGroups?, groupsClaim? }
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/oauth2/callback/<id>
# OIDC_PROVIDERS='[{"id":"authentik","name":"Authentik","clientId":"...","clientSecret":"...","discoveryUrl":"https://auth.example.com/application/o/app/.well-known/openid-configuration"}]'

# --- OIDC (legacy single provider, still supported) --------------------
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_DISCOVERY_URL=
# OIDC_PROVIDER_ID=authentik

# --- Google login -------------------------------------------------------
# Setting both client vars enables "Sign in with Google"; GOOGLE_LOGIN_ENABLED
# controls whether the login button is shown.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_LOGIN_ENABLED=false

# --- Sign in with Apple -------------------------------------------------
# Required by App Store guideline 4.8 when the iOS app offers Google login.
# APPLE_CLIENT_ID is the *Services ID* (not the app bundle id), created in the
# Apple Developer portal with "Sign in with Apple" enabled and
# ${BETTER_AUTH_URL}/api/auth/callback/apple registered as a Return URL.
# The client secret is an ES256 JWT Apple caps at 6 months — provide the SIWA
# .p8 key instead (base64 -w0 AuthKey_XXX.p8, like GITHUB_APP_PRIVATE_KEY) and
# the server mints a fresh secret at every boot. A static APPLE_CLIENT_SECRET
# is still honored (and wins) if you prefer minting it yourself.
# APPLE_APP_BUNDLE_IDENTIFIER is optional: only needed if the iOS app ever
# exchanges a native ASAuthorization idToken directly.
# APPLE_CLIENT_ID=
# APPLE_PRIVATE_KEY=
# APPLE_KEY_ID=
# APPLE_TEAM_ID=
# APPLE_CLIENT_SECRET=
# APPLE_LOGIN_ENABLED=false
# APPLE_APP_BUNDLE_IDENTIFIER=at.exponential

# --- Feedback widget ----------------------------------------------------
# Self-hosted: embed the cloud's feedback widget in this instance's sidebar
# (analog of PUBLIC_FEEDBACK_URL). Both must be set; the script origin is
# also added to the CSP script-src when SECURITY_HEADERS_ENABLED=true.
# FEEDBACK_WIDGET_SCRIPT_URL=https://app.exponential.at/widget/v1/loader.js
# FEEDBACK_WIDGET_KEY=expw_...
# Rate limits for the public widget submit endpoint (in-process buckets):
# WIDGET_RATE_LIMIT_PER_KEY_HOURLY=60
# WIDGET_RATE_LIMIT_KEY_BURST=10
# WIDGET_RATE_LIMIT_PER_IP_HOURLY=60
# WIDGET_RATE_LIMIT_IP_BURST=5

# --- Push notifications (via push-relay service) -----------------------
# URL of the push-relay service (e.g. https://push.yourapp.com)
# PUSH_RELAY_URL=

# --- Steer relay (remote start + live watch/steer) ---------------------
# Outbound WebSocket hub. Unset ⇒ subsystem off (mintTicket returns disabled;
# local coding unaffected). STEER_RELAY_URL is what desktop + clients dial
# (wss://steer.exponential.at, or ws://relay.lan:4002 on LAN self-host); the web
# app derives the http(s) origin for its server-to-server /devices, /start, /kill
# calls. STEER_RELAY_SECRET is the shared HS256 secret (must match the relay) —
# the web app signs tickets + authenticates relay calls with it.
# STEER_RELAY_URL=
# STEER_RELAY_SECRET=

# --- GitHub webhook (cloud PR-merge detection) -------------------------
# GitHub webhook HMAC secret; cloud merge detection. Set a repo/org webhook
# pointing at ${BETTER_AUTH_URL}/api/webhooks/github with this same secret.
# GITHUB_WEBHOOK_SECRET=

# --- MCP server --------------------------------------------------------
# The MCP endpoint at /api/mcp uses OAuth (via better-auth's `mcp` plugin)
# with Dynamic Client Registration + PKCE. Each client logs in as a real
# user via /auth/login, so no API token env vars are required.

# --- Dev / debugging ---------------------------------------------------
# Set to "1" to hide the TanStack Router devtools panel
# DISABLE_ROUTER_DEVTOOLS=1
# Same toggle, but read at build time by Vite
# VITE_DISABLE_ROUTER_DEVTOOLS=1
