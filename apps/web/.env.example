# The web app's runtime env file is a symlink to the repo-root `.env`
# (see `apps/web/.env -> ../../.env`). This file documents every variable
# the web app actually reads; copy what you need into the root `.env`.

# --- Core / required ---------------------------------------------------
# PostgreSQL connection string used by Drizzle and tRPC
DATABASE_URL=postgresql://postgres:password@localhost:54321/electric
# 32+ char secret used by Better Auth to sign sessions
BETTER_AUTH_SECRET=
# Base URL of the app, used by Better Auth for OAuth callbacks
BETTER_AUTH_URL=http://localhost:5173
# Comma-separated list of origins Better Auth will accept requests from
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173

# --- ElectricSQL --------------------------------------------------------
# Defaults to http://localhost:30000 (the local docker compose service)
ELECTRIC_URL=http://localhost:30000
# Optional Electric Cloud credentials (only when using hosted Electric)
# ELECTRIC_SOURCE_ID=
# ELECTRIC_SECRET=

# --- S3-compatible attachment storage (Garage by default) --------------
# Run `bun run storage:init` to bootstrap credentials
S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=exponential-attachments
S3_REGION=garage

# --- Self-hosting ------------------------------------------------------
# 'true' disables billing and unlocks every plan limit (seats/storage/
# widgets). A product switch only — the licence headcount cap is
# contract-only (see /LICENSE).
# SELF_HOSTED=true

# --- Authentication toggles --------------------------------------------
# Disable email/password sign-in (default: enabled)
# AUTH_PASSWORD_ENABLED=false
# Public password sign-up ('true'/'false'; default: on in dev, OFF in
# production builds)
# AUTH_SIGNUP_ENABLED=true
# Legacy single-provider OIDC switch (see OIDC_PROVIDERS for the new form)
# AUTH_OIDC_ENABLED=true

# --- OIDC (multi-provider) ---------------------------------------------
# JSON array; each entry: { id, name, clientId, clientSecret, discoveryUrl,
#   scopes?, adminGroups?, groupsClaim? }
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/oauth2/callback/<id>
# OIDC_PROVIDERS='[{"id":"authentik","name":"Authentik","clientId":"...","clientSecret":"...","discoveryUrl":"https://auth.example.com/application/o/app/.well-known/openid-configuration"}]'

# --- OIDC (legacy single provider, still supported) --------------------
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_DISCOVERY_URL=
# OIDC_PROVIDER_ID=authentik

# --- Google login -------------------------------------------------------
# Setting both client vars enables "Sign in with Google"; GOOGLE_LOGIN_ENABLED
# controls whether the login button is shown.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_LOGIN_ENABLED=false

# --- Sign in with Apple -------------------------------------------------
# Required by App Store guideline 4.8 when the iOS app offers Google login.
# APPLE_CLIENT_ID is the *Services ID* (not the app bundle id), created in the
# Apple Developer portal with "Sign in with Apple" enabled and
# ${BETTER_AUTH_URL}/api/auth/callback/apple registered as a Return URL.
# The client secret is an ES256 JWT Apple caps at 6 months — provide the SIWA
# .p8 key instead (base64 -w0 AuthKey_XXX.p8, like GITHUB_APP_PRIVATE_KEY) and
# the server mints a fresh secret at every boot. A static APPLE_CLIENT_SECRET
# is still honored (and wins) if you prefer minting it yourself.
# APPLE_APP_BUNDLE_IDENTIFIER is optional: only needed if the iOS app ever
# exchanges a native ASAuthorization idToken directly.
# APPLE_CLIENT_ID=
# APPLE_PRIVATE_KEY=
# APPLE_KEY_ID=
# APPLE_TEAM_ID=
# APPLE_CLIENT_SECRET=
# APPLE_LOGIN_ENABLED=false
# APPLE_APP_BUNDLE_IDENTIFIER=at.exponential

# --- Outbound email (Amazon SES or SMTP) -------------------------------
# ALL outgoing mail (password reset/verification, invite emails, the
# notification digest, helpdesk magic links, contact form). Unset both
# transports ⇒ email features are silently off. SES wins when both are set.
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY ride the standard AWS SDK env
# chain (IAM user with ses:SendEmail).
# AWS_SES_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# EMAIL_FROM="Exponential <noreply@example.com>"
# Monitored default Reply-To on every outbound email (per-send replyTo wins).
# EMAIL_REPLY_TO=support@example.com
# SMTP alternative (self-host):
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
# Shared secret for the SES bounce/complaint SNS webhook (SNS HTTPS
# subscription → ${BETTER_AUTH_URL}/api/webhooks/ses?secret=…). Unset =
# bounce tracking off.
# SES_WEBHOOK_SECRET=
# Recipient of the marketing-site contact form (POST /api/contact; 503 when
# no email transport is configured).
# CONTACT_EMAIL_TO=support@exponential.at
# Contact-form rate limits (in-process buckets):
# CONTACT_RATE_LIMIT_PER_IP_HOURLY=10
# CONTACT_RATE_LIMIT_IP_BURST=3
# CONTACT_RATE_LIMIT_GLOBAL_HOURLY=30
# CONTACT_RATE_LIMIT_GLOBAL_BURST=10

# --- Billing (Creem, cloud-only) ---------------------------------------
# Leave unset when self-hosting (SELF_HOSTED=true turns billing off anyway).
# CREEM_API_KEY=
# CREEM_WEBHOOK_SECRET=
# CREEM_PRO_PRODUCT_ID=
# CREEM_BUSINESS_PRODUCT_ID=
# CREEM_BUSINESS_YEARLY_PRODUCT_ID=

# --- Server hardening / bootstrap --------------------------------------
# 'true' to emit CSP/HSTS etc. from the Bun server
# SECURITY_HEADERS_ENABLED=true
# Comma-separated emails auto-promoted to global admin at startup
# INITIAL_ADMIN_EMAILS=
# Bun runtime knob (not app config): cap on simultaneous outbound fetch()
# calls, default 256. The Electric shape proxy holds 14 long-poll fetches per
# synced client, so 256 saturates at ~18 clients and stalls all other outbound
# fetches. Read by Bun at process start — the official Docker image bakes it
# via ENV; if you run the compiled server yourself, export it in the actual
# process environment rather than relying on this file.
# BUN_CONFIG_MAX_HTTP_REQUESTS=65336

# --- Feedback widget ----------------------------------------------------
# Self-hosted instances do not embed the cloud widget (its key is
# domain-allowlisted to the cloud); without a widget of their own the
# sidebar feedback button simply doesn't render.
# Rate limits for the public widget submit endpoint (in-process buckets):
# WIDGET_RATE_LIMIT_PER_KEY_HOURLY=60
# WIDGET_RATE_LIMIT_KEY_BURST=10
# WIDGET_RATE_LIMIT_PER_IP_HOURLY=60
# WIDGET_RATE_LIMIT_IP_BURST=5
# Per reporter address (submissions carrying an email can trigger outbound
# mail to it — this bucket stops mail-bombing a typed-in address):
# WIDGET_RATE_LIMIT_PER_EMAIL_HOURLY=6
# WIDGET_RATE_LIMIT_EMAIL_BURST=3

# --- Helpdesk reporter routes (magic-link read/reply) ------------------
# Rate limits for the anonymous /api/support/* routes (in-process buckets):
# SUPPORT_RATE_LIMIT_READ_HOURLY=300
# SUPPORT_RATE_LIMIT_READ_BURST=30
# SUPPORT_RATE_LIMIT_REPLY_IP_HOURLY=30
# SUPPORT_RATE_LIMIT_REPLY_IP_BURST=5
# SUPPORT_RATE_LIMIT_REPLY_THREAD_HOURLY=30
# SUPPORT_RATE_LIMIT_REPLY_THREAD_BURST=5
# Live-chat poll (~5s per visible tab; also the presence heartbeat that
# suppresses "new reply" emails while the reporter is watching):
# SUPPORT_RATE_LIMIT_POLL_HOURLY=1440
# SUPPORT_RATE_LIMIT_POLL_BURST=90

# --- Push notifications (via push-relay service) -----------------------
# URL of the push-relay service (e.g. https://push.yourapp.com)
# PUSH_RELAY_URL=
# Shared secret sent as the x-relay-secret header — must equal the relay
# process's PUSH_RELAY_SECRET. The relay refuses to start without one, so
# always set this together with PUSH_RELAY_URL (URL without secret means
# every push is rejected with 401).
# PUSH_RELAY_SECRET=

# --- Steer relay (remote start + live watch/steer) ---------------------
# Outbound WebSocket hub. Unset ⇒ subsystem off (mintTicket returns disabled;
# local coding unaffected). STEER_RELAY_URL is what desktop + clients dial
# (wss://steer.exponential.at, or ws://relay.lan:4002 on LAN self-host); the web
# app derives the http(s) origin for its server-to-server /devices, /start, /kill
# calls. STEER_RELAY_SECRET is the shared HS256 secret (must match the relay) —
# the web app signs tickets + authenticates relay calls with it.
# STEER_RELAY_URL=
# STEER_RELAY_SECRET=

# --- GitHub App (dev projects / coding flow) ---------------------------
# Full setup notes live in the root .env.example. App settings must point
# Setup URL → /api/integrations/github/setup ("Redirect on update" ticked),
# OAuth Callback URL → /api/integrations/github/callback, and subscribe the
# Pull request event (installation/installation_repositories arrive
# automatically once the webhook is Active — no checkbox exists for them).
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=
# GITHUB_APP_PRIVATE_KEY=
# OAuth client credentials for the workspace "Connect GitHub" claim flow
# (transient user token, never stored). Unset ⇒ install-page fallback.
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=

# --- GitHub webhook (cloud PR-merge detection) -------------------------
# GitHub webhook HMAC secret; cloud merge detection. Set a repo/org webhook
# pointing at ${BETTER_AUTH_URL}/api/webhooks/github with this same secret.
# GITHUB_WEBHOOK_SECRET=
# 'true' to run the outbound merge-detection cron instead (self-hosted
# behind NAT, unreachable by webhook).
# GITHUB_POLLING=true

# --- Mobile app links (EXP-92) -----------------------------------------
# SHA-256 signing-cert fingerprints served in /.well-known/assetlinks.json so
# Android verifies https issue/invite links and opens them in the native app.
# Comma-separated colon-hex, from Play Console → App integrity → app signing
# key certificate (Play App Signing — NOT the local upload keystore). Unset ⇒
# the route 404s and links keep opening in the browser. The iOS counterpart
# (/.well-known/apple-app-site-association) is static and needs no env.
# ANDROID_APP_LINK_FINGERPRINTS=AA:BB:...,CC:DD:...

# --- Minimum client versions -------------------------------------------
# Native clients send `x-client-version: <platform>/<version>` on every
# request; when a platform's MIN var is set and a client compares below it,
# tRPC + shape requests answer HTTP 426 and the app shows its blocking
# update screen. Unset = gate off (fail-open). LATEST is informational only
# (GET /api/version + the 426 body). Values are ALWAYS the marketing version
# (Android versionName, iOS CFBundleShortVersionString, desktop tag version —
# e.g. 0.13.3), NEVER an Android versionCode or iOS build number: `40` is a
# numerically valid value that would instantly 426 every header-sending client.
# CLIENT_MIN_VERSION_ANDROID=
# CLIENT_MIN_VERSION_IOS=
# CLIENT_MIN_VERSION_DESKTOP=
# CLIENT_LATEST_VERSION_ANDROID=
# CLIENT_LATEST_VERSION_IOS=
# CLIENT_LATEST_VERSION_DESKTOP=

# --- MCP server --------------------------------------------------------
# The MCP endpoint at /api/mcp uses OAuth (via better-auth's `mcp` plugin)
# with Dynamic Client Registration + PKCE. Each client logs in as a real
# user via /auth/login, so no API token env vars are required.

# --- Dev / debugging ---------------------------------------------------
# Set to "1" to hide the TanStack Router devtools panel
# DISABLE_ROUTER_DEVTOOLS=1
# Same toggle, but read at build time by Vite
# VITE_DISABLE_ROUTER_DEVTOOLS=1
