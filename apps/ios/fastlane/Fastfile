# fastlane lanes for the Exponential iOS app (apps/ios), layered on top of Tuist.
#
# Runs locally on a Mac with Xcode + Tuist. No CI Mac runner is required for launch —
# see docs/release-ios.md for the full procedure.
#
# The Xcode project/workspace is NOT committed (Tuist-generated), so `build` regenerates
# it first. Non-interactive uploads authenticate with an App Store Connect API key read
# from env (ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_PATH).

default_platform(:ios)

WORKSPACE = "Exponential.xcworkspace".freeze
SCHEME = "Exponential".freeze # production target (bundle id at.exponential)
IPA_PATH = "build/Exponential.ipa".freeze

def asc_api_key
  # App Store Connect API key (Users & Access → Integrations → App Store Connect API).
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_PATH"),
  )
end

platform :ios do
  desc "Regenerate the Tuist project and build a signed App Store archive (.ipa)."
  lane :build do
    # `sh` runs from the fastlane/ dir, so step up to apps/ios to regenerate the project.
    sh("cd .. && tuist generate --no-open")

    # Hand the ASC API key to xcodebuild so automatic signing can mint the
    # cloud-managed Distribution certificate + App Store profiles headlessly
    # (first run on a fresh Mac has neither).
    auth_xcargs = [
      "-allowProvisioningUpdates",
      "-authenticationKeyPath #{File.expand_path(ENV.fetch('ASC_KEY_PATH'))}",
      "-authenticationKeyID #{ENV.fetch('ASC_KEY_ID')}",
      "-authenticationKeyIssuerID #{ENV.fetch('ASC_ISSUER_ID')}",
    ].join(" ")

    gym(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      output_name: "Exponential.ipa",
      xcargs: auth_xcargs, # gym forwards these to -exportArchive too
    )
  end

  desc "Regenerate the Tuist project and capture App Store screenshots (snapshot)."
  desc "Needs the seeded local backend (apps/web/scripts/seed-screenshots.ts) at"
  desc "http://localhost:5173 — override with SNAPSHOT_INSTANCE_URL."
  lane :screenshots do
    sh("cd .. && tuist generate --no-open")
    # The sign-in flow types into text fields — make sure the simulators show
    # the software keyboard instead of assuming a connected hardware keyboard.
    sh("defaults write com.apple.iphonesimulator ConnectHardwareKeyboard -bool false || true")
    snapshot
  end

  desc "Build + upload to TestFlight (pilot). Internal-only by default (fast: skips the"
  desc "processing wait). `fastlane beta external:true` also distributes to the external"
  desc "group (TESTFLIGHT_EXTERNAL_GROUP, default 'External Testers') — this waits for"
  desc "build processing, attaches the What-to-Test changelog (TESTFLIGHT_CHANGELOG env,"
  desc "falling back to metadata/en-US/release_notes.txt), and auto-submits the build for"
  desc "Beta App Review. The external group + TestFlight Test Information must already"
  desc "exist in App Store Connect (see docs/release-ios.md → External TestFlight)."
  lane :beta do |options|
    build
    pilot_args = {
      api_key: asc_api_key,
      ipa: IPA_PATH,
    }
    if options[:external]
      pilot_args.merge!(
        distribute_external: true,
        groups: [ENV.fetch("TESTFLIGHT_EXTERNAL_GROUP", "External Testers")],
        # Apple requires a What-to-Test changelog on externally distributed builds.
        # Lanes run with fastlane/ as the working directory, so the metadata
        # path is NOT prefixed with fastlane/.
        changelog: ENV["TESTFLIGHT_CHANGELOG"] ||
          File.read("metadata/en-US/release_notes.txt").strip,
        # No skip_waiting_for_build_processing here: pilot can only assign the
        # external group (and submit for Beta App Review) once processing finishes.
      )
    else
      pilot_args.merge!(
        skip_waiting_for_build_processing: true,
        distribute_external: false,
      )
    end
    pilot(**pilot_args)
  end

  desc "Upload listing metadata + screenshots to App Store Connect WITHOUT building."
  desc "Metadata lives in fastlane/metadata/, screenshots in fastlane/screenshots/."
  lane :sync_store do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true, # skip the interactive HTML preview
      run_precheck_before_submit: false,
      submit_for_review: false,
      precheck_include_in_app_purchases: false,
    )
  end

  desc "Build + upload to App Store Connect (deliver). Does NOT auto-submit for review."
  lane :release do
    build
    deliver(
      api_key: asc_api_key,
      ipa: IPA_PATH,
      submit_for_review: false,
      force: true, # skip the interactive HTML preview
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false,
    )
  end
end

# ── Signing bootstrap (match) — COMMENTED until account setup (masterplan §13) ──────
#
# Signing is intentionally NOT wired here yet. At Apple-account setup we decide between:
#
#   (a) match — Distribution cert + App Store profiles stored in a private git repo,
#       shared across machines/CI. Seed once with `bundle exec fastlane match appstore`,
#       then add this to `build` BEFORE the gym call:
#
#         match(
#           type: "appstore",
#           app_identifier: "at.exponential",
#           git_url: ENV.fetch("MATCH_GIT_URL"),
#           readonly: true,
#         )
#
#   (b) Developer-portal-managed profiles — let Xcode "automatically manage signing"
#       (team V6W7BVCSM8, already set as DEVELOPMENT_TEAM in Project.swift), or pass a
#       manual profile to gym via export_options:
#
#         export_options: {
#           signingStyle: "manual",
#           provisioningProfiles: { "at.exponential" => "Exponential App Store" },
#         }
#
# Until one is chosen, `build` relies on Xcode's automatic signing resolving the team's
# Distribution certificate + profile (same as the manual Organizer flow).
