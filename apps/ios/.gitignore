# Tuist-generated
*.xcodeproj
*.xcworkspace
Derived/
.build/
.swiftpm/

# Xcode
xcuserdata/
*.xcuserstate
DerivedData/
build/

# fastlane
fastlane/report.xml
fastlane/Preview.html
# snapshot output (screenshots + HTML summary) — regenerated by `fastlane screenshots`
fastlane/screenshots/
fastlane/test_output
*.ipa
*.xcarchive
# App Store Connect API key (.p8) — path comes from ASC_KEY_PATH; never commit a key
fastlane/*.p8
.bundle/
vendor/bundle/

# macOS
.DS_Store

# Firebase iOS client config (GoogleService-Info.plist) is committed: it's not a
# secret — it ships inside every app binary and its api_key/app_id are project
# identifiers restricted by bundle-id + Firebase rules (matches Android's tracked
# google-services.json). The Firebase ADMIN service account stays in env only.
