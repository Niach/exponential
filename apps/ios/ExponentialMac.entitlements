<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Developer tool: intentionally NOT App-Sandboxed — it spawns CLIs (git
	     and, for the local device preview, dev servers / emulators) in worktrees
	     on disk. The Hardened Runtime is on (ENABLE_HARDENED_RUNTIME=YES); the
	     allow-jit / allow-unsigned-executable-memory exceptions let the embedded
	     libghostty terminal's GPU renderer use Metal + JIT-style executable memory.
	     TODO: disable-library-validation was originally needed to load the
	     agent-core dylib from Contents/Frameworks. That dylib is gone (GhosttyKit
	     is statically linked), so this exception should be re-evaluated / dropped
	     on real hardware — kept for now to avoid a codesign surprise. -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
</dict>
</plist>
