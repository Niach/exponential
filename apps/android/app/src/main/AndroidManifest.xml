<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".ExponentialApp"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Exponential"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Exponential"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- OAuth return (REV-13): a custom scheme can never be an App Link
                 (autoVerify only works for http/https), so any co-installed app
                 declaring this same scheme+host filter can win the implicit-intent
                 resolution. That is safe because the link carries only a
                 single-use, short-TTL PKCE code — useless without the in-app
                 code_verifier that /api/mobile-oauth-exchange requires — never
                 the session token. (Pre-PKCE servers still send a raw token;
                 that legacy path is deprecated server-side.) -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="exponential" android:host="oauth-return" />
            </intent-filter>

            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="exponential" android:host="issue" />
            </intent-filter>

            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="exponential" android:host="invite" />
            </intent-filter>

            <!-- App Links (EXP-92): verified https links open the app instead of
                 the mobile web. Host is per-flavor (production app.exponential.at,
                 staging next.exponential.at); verification needs the host to serve
                 /.well-known/assetlinks.json with this build's signing cert (env
                 ANDROID_APP_LINK_FINGERPRINTS on the web app — Play App Signing
                 key for store installs). Only the two shapes the app can render
                 are claimed: issue detail + invites; unresolvable links fall back
                 to a Custom Tab in AppNavHost. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="${appLinkHost}" />
                <!-- Both board prefixes are claimed: the web moved /w/ → /t/
                     (workspaces → teams rename, EXP-122) but /w/ stays valid
                     permanently for old links. -->
                <data android:pathPattern="/w/.*/projects/.*/issues/.*" />
                <data android:pathPattern="/t/.*/projects/.*/issues/.*" />
                <data android:pathPrefix="/invite/" />
            </intent-filter>

            <!-- Fired by the server's post-GitHub-App-install page so the connect
                 flow returns into the app instead of continuing in the browser. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="exponential" android:host="github-connected" />
            </intent-filter>

            <!-- Share target: a shared link/text or a single image becomes a new issue. -->
            <intent-filter android:label="@string/app_name">
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/*" />
                <data android:mimeType="image/*" />
            </intent-filter>

            <!-- Share target: multiple shared images become one new issue. -->
            <intent-filter android:label="@string/app_name">
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
        </activity>

        <service
            android:name=".data.push.FcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- The push relay sends notification-type FCM messages, so with the
             app backgrounded the FCM SDK renders the notification itself
             (FcmService is never called) and would fall back to the launcher
             icon — which is not alpha-safe for the status bar (EXP-143). -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_notification" />

    </application>

</manifest>
