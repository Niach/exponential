<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground: ports apps/web/public/logo-light.svg into a
  108dp viewport. The original SVG is 100x100 with a circle r=50 centered
  at (50,50) and three thick stroke curves clipped to the circle by a mask.

  Android vector drawables don't support SVG masks, so we render the same
  composition by stacking layers: a white filled circle on top, then three
  dark strokes the same color as ic_launcher_background. Outside the white
  circle the dark strokes paint over the (already dark) background and are
  invisible; inside, they look like the cuts from the original mask.

  Scale = 29/50 so the white circle sits inside the 33dp round-mask safe
  zone of the 108dp adaptive-icon viewport (centered at 54,54) with a 4dp
  margin — full-bleed to the safe zone read cramped next to other launcher
  icons (EXP-143).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:fillColor="#FAFAFA"
        android:pathData="M 54,25 A 29,29 0 1,0 54,83 A 29,29 0 1,0 54,25 Z" />

    <path
        android:strokeColor="#09090B"
        android:strokeWidth="3.5"
        android:strokeLineCap="butt"
        android:fillColor="#00000000"
        android:pathData="M 21.60,60.97 C 47.67,62.96 53.26,41.65 53.44,21.40" />
    <path
        android:strokeColor="#09090B"
        android:strokeWidth="3.5"
        android:strokeLineCap="butt"
        android:fillColor="#00000000"
        android:pathData="M 22.06,74.88 C 56.19,73.96 66.26,46.63 67.34,22.05" />
    <path
        android:strokeColor="#09090B"
        android:strokeWidth="3.5"
        android:strokeLineCap="butt"
        android:fillColor="#00000000"
        android:pathData="M 22.52,88.79 C 64.71,84.97 79.26,51.60 81.25,22.69" />
</vector>
