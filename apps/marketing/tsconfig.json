{
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["../web/src/*"],
      "@video/*": ["../video/src/*"],
      "@remotion/google-fonts/Inter": ["src/movie/fonts/inter-shim.ts"],
      "@remotion/google-fonts/JetBrainsMono": [
        "src/movie/fonts/jetbrains-shim.ts"
      ]
    }
  }
}
